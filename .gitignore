# ============================================================
# BankBI .gitignore
# ============================================================

# ----------------------------------------------------------
# OS
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----------------------------------------------------------
# IDEs and Editors
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ----------------------------------------------------------
# Backend (Rails)
# ----------------------------------------------------------
backend/.bundle/
backend/vendor/bundle
backend/log/*
backend/tmp/*
backend/db/*.sqlite3
backend/db/*.sqlite3-*
backend/storage/*
backend/public/uploads
backend/public/packs
backend/public/packs-test
backend/node_modules
backend/.byebug_history
backend/coverage/

# ----------------------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------------------
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/node_modules/
frontend/.vercel
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ----------------------------------------------------------
# HTML Prototype (reference only)
# ----------------------------------------------------------
bankbi/

# ----------------------------------------------------------
# Dependencies
# ----------------------------------------------------------
node_modules/
bower_components/

# ----------------------------------------------------------
# Environment Variables (NEVER commit secrets)
# ----------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
backend/.env
backend/.env.local
backend/.env.production
backend/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ----------------------------------------------------------
# Credentials (NEVER commit)
# ----------------------------------------------------------
credentials.yml.enc
master.key
*.pem
*.key
*.crt
config/master.key
config/credentials/production.key

# ----------------------------------------------------------
# Database / Data files (local reference only)
# ----------------------------------------------------------
*.sqlite
*.sqlite3
*.db
postgres_data/
redis_data/
dump.rdb

# Root-level legacy data files (now organized under data/)
call procedure prem.sql
transummary procedure.sql
sample data.csv
data dictionary.xlsx

# ----------------------------------------------------------
# Testing
# ----------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/
.pytest_cache/
.rspec_status

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
*.log
logs/
*.log.*

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
docker-compose.override.yml

# ----------------------------------------------------------
# Temp / Cache / Build artifacts
# ----------------------------------------------------------
*.tmp
*.temp
*.cache
.cache/
*.com
*.class
*.dll
*.exe
*.o
*.so
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ----------------------------------------------------------
# Backup files
# ----------------------------------------------------------
*.bak
*.backup
*.old

# ----------------------------------------------------------
# Uploads / User data
# ----------------------------------------------------------
uploads/
tmp/storage/

# ----------------------------------------------------------
# Documentation builds
# ----------------------------------------------------------
docs/_build/
site/

# ----------------------------------------------------------
# Ruby
# ----------------------------------------------------------
*.gem
*.rbc
/.config
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/.bundle
/vendor/bundle

# ----------------------------------------------------------
# Python (utility scripts)
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
ENV/
env/

# ----------------------------------------------------------
# Keep template files tracked
# ----------------------------------------------------------
!backend.Dockerfile.template
!frontend.Dockerfile.template

# ----------------------------------------------------------
