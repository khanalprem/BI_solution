# Frontend Environment Variables Template
# Copy this to frontend/.env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001/cable

# Application Configuration
NEXT_PUBLIC_APP_NAME=BankBI
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_EXPORT=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Map Configuration (Optional - for branch maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Nepal Specific
NEXT_PUBLIC_DEFAULT_CURRENCY=NPR
NEXT_PUBLIC_TIMEZONE=Asia/Kathmandu
NEXT_PUBLIC_LOCALE=en-NP

# Chart Configuration
NEXT_PUBLIC_CHART_COLORS='["#3b82f6","#10b981","#f59e0b","#ef4444","#8b5cf6"]'

# UI Configuration
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true

# Development Only
NEXT_PUBLIC_DEBUG=false
