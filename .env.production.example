# Copy to .env.production and fill in values.
# Generate secrets with: openssl rand -hex 64
# This file is loaded by docker-compose.prod.yml via --env-file.

# ============================================================
# Required - app refuses to boot without these
# ============================================================
JWT_SECRET_KEY=
SECRET_KEY_BASE=
FRONTEND_URL=https://nbl.nepseflow.com
APP_HOST=nbl.nepseflow.com

# ============================================================
# Production warehouse (NiFi) - read CLAUDE.md SAFETY notes first
# Both backend and sidekiq containers connect here.
# ============================================================
DATABASE_HOST=10.1.1.161
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=nifi

# ============================================================
# Rails runtime
# ============================================================
RAILS_ENV=production
RACK_ENV=production
RAILS_MAX_THREADS=10
RAILS_LOG_LEVEL=info
JWT_EXPIRATION_HOURS=8

# ============================================================
# Risk thresholds (optional - service has defaults)
# ============================================================
# RISK_HIGH_VALUE_THRESHOLD=10000000
# RISK_CONCENTRATION_WARN=0.20
# RISK_CONCENTRATION_HIGH=0.40
# RISK_VOLATILITY_WARN=25
# RISK_VOLATILITY_HIGH=40

# ============================================================
# Email (optional)
# ============================================================
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_DOMAIN=
# SMTP_USERNAME=
# SMTP_PASSWORD=
